{
    "_schemaVersion": "1.0.0",

    "noiseXu":
    {
        "inputs":
        [
            {"name":"N", "kind":"required", "type":["numeric", "positive", "integer", "scalar"]},
            {"name":"alpha", "kind":"required", "type":["numeric", "scalar"]},
            {"name":"amplitude", "kind":"ordered", "type":["numeric", "nonnegative", "scalar"]},
            {"name":"fs", "kind":"ordered", "type":["numeric", "positive", "scalar"]},
            {"name":"Phi", "kind":"namevalue", "type":["numeric", "scalar"]}
        ],
        "outputs":
        [
            {"name":"noise", "type":["numeric", "column"]}
        ]
    },

    "shapeNoise":
    {
        "inputs":
        [
            {"name":"resid", "kind":"required", "type":["numeric", "column"]},
            {"name":"fs", "kind":"required", "type":["numeric", "positive", "scalar"]},
            {"name":"alpha", "kind":"required", "type":["numeric", "scalar"]},
            {"name":"PhaseSource", "kind":"namevalue", "type":[["choices={'xu','white','pinknoise','dsp'}"], "function_handle"]}
        ],
        "outputs":
        [
            {"name":"n", "type":["numeric", "column"]}
        ]
    },

    "estimateIRASA":
    {
        "inputs":
        [
            {"name":"x", "kind":"required", "type":["numeric", "column"]},
            {"name":"fs", "kind":"required", "type":["numeric", "positive", "scalar"]},
            {"name":"fLow", "kind":"required", "type":["numeric", "positive", "scalar"]},
            {"name":"fHigh", "kind":"required", "type":["numeric", "positive", "scalar"]},
            {"name":"Hset", "kind":"namevalue", "type":["numeric", "vector"]},
            {"name":"CompareFieldTrip", "kind":"namevalue", "type":["logical", "scalar"]},
            {"name":"ComparePMTM", "kind":"namevalue", "type":["logical", "scalar"]}
        ],
        "outputs":
        [
            {"name":"alphaEst", "type":["numeric", "scalar"]},
            {"name":"sigmaEst", "type":["numeric", "scalar"]},
            {"name":"pFractal", "type":["numeric", "column"]},
            {"name":"fVec", "type":["numeric", "column"]},
            {"name":"ftInfo", "type":["struct", "scalar"]},
            {"name":"pmInfo", "type":["struct", "scalar"]}
        ]
    },

    "checkSpectralKnee":
    {
        "inputs":
        [
            {"name":"resid", "kind":"required", "type":["numeric", "column"]},
            {"name":"fs", "kind":"required", "type":["numeric", "positive", "scalar"]},
            {"name":"FitBandLow", "kind":"namevalue", "type":["numeric", "positive", "scalar"]},
            {"name":"WideBandLow", "kind":"namevalue", "type":["numeric", "positive", "scalar"]},
            {"name":"FitBandHigh", "kind":"namevalue", "type":["numeric", "nonnegative", "scalar"]},
            {"name":"Hset", "kind":"namevalue", "type":["numeric", "vector"]},
            {"name":"ExtraKneeStarts", "kind":"namevalue", "type":["numeric", "vector"]}
        ],
        "outputs":
        [
            {"name":"result", "type":["struct", "scalar"]}
        ]
    }
}
